{
  "name": "almi-french",
  "version": "0.1.0",
  "private": true,
  "description": "AlmiFrench — AI-powered French exam practice in the AlmiWorld family. TEF, TCF, DELF and DALF across four skills and six CEFR levels (A1–C2), with three honest scoring engines mapping to CEFR and Canada's NCLC. Separate product (almifrench.almiworld.com). Original French content — never copied from the test-makers. Practice estimates only; confirm with the official body.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "seed:b1": "tsx scripts/seed/b1.ts",
    "seed:b2": "tsx scripts/seed/b2.ts",
    "seed:c1": "tsx scripts/seed/c1.ts",
    "seed:append": "tsx scripts/seed/append.ts",
    "validate:seed": "tsx scripts/validate-seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "next": "16.2.6",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.3",
    "stripe": "^22.1.0",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
